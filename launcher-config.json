{
  "launcherName": "BongLauncher",
  "windowTitle": "봉봉리 전용 런처",
  "notice": {
    "title": "서버 전용 런처에 오신 것을 환영합니다",
    "message": "서버 접속에 필요한 모드와 리소스팩을 자동으로 설치합니다. 문제가 발생하면 파일 검사를 실행해 주세요."
  },
  "server": {
    "name": "Bongbongli",
    "host": "bongbongli.kr",
    "port": 25565,
    "autoConnect": true,
    "acceptResourcePacks": true
  },
  "minecraft": {
    "version": "1.21.4",
    "loader": "fabric",
    "loaderVersion": "",
    "minMemoryMb": 2048,
    "maxMemoryMb": 4096,
    "javaMajor": 21
  },
  "microsoft": {
    "clientId": "b6fceb2d-e91d-424e-a3ca-2441fb165ab0"
  },
  "distribution": {
    "manifestUrl": "",
    "strictMode": true,
    "watchDirectories": [
      "mods",
      "resourcepacks",
      "config",
      "shaderpacks"
    ],
    "onceFiles": [
      "options.txt",
      "servers.dat"
    ],
    "ignoredFiles": [
      "options.txt",
      "server.dat",
      "config/iris.properties",
      "usercache.json",
      "logs/**",
      "crash-reports/**",
      "screenshots/**",
      "saves/**"
    ]
  },
  "updates": {
    "enabled": true,
    "provider": "github",
    "owner": "MrKJK",
    "repo": "BongLauncher",
    "remoteConfigUrl": "https://MrKJK.github.io/BongLauncher/launcher-config.json",
    "checkOnStart": true
  },
  "gameOptions": {
    "applyMode": "once",
    "lang": "ko_kr",
    "resourcePacks": [
      "vanilla",
      "fabric",
      "continuity:glass_pane_culling_fix",
      "continuity:default",
      "file/봉봉리_애니메이션2.zip",
      "file/봉봉리_애니메이션1.zip",
      "file/봉봉리_3D.zip",
      "file/[셰이더 유저 추천]봉봉리_하늘.zip"
    ],
    "incompatibleResourcePacks": [
      "enchdesc",
      "entity_model_features",
      "entity_texture_features",
      "koreanpatch",
      "modernfix",
      "yet_another_config_lib_v3"
    ],
    "keyBindings": {}
  },
  "security": {
    "launcherHandshakeUrl": "",
    "publicKeyPem": "",
    "tokenTtlSeconds": 120
  }
}
